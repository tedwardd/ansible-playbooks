server:
  http_listen_port: {{ promtail_http_listen_port }}
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: {{ promtail_loki_url }}

scrape_configs:
{% if promtail_scrape_nginx %}
  - job_name: nginx
    static_configs:
      - targets:
          - localhost
        labels:
          job: nginx
          host: {{ ansible_hostname }}
          __path__: /var/log/nginx/access.log
    pipeline_stages:
      - regex:
          expression: '^(?P<remote_addr>\S+) - (?P<remote_user>\S+) \[(?P<time_local>[^\]]+)\] "(?P<method>\S+) (?P<request_uri>\S+) \S+" (?P<status>\d+) (?P<body_bytes_sent>\d+)'
      - geoip:
          db: /usr/share/GeoIP/GeoLite2-City.mmdb
          source: remote_addr
          db_type: city
      - labels:
          method:
          status:
          geoip_country_iso_code:
          geoip_country_name:

  - job_name: nginx-error
    static_configs:
      - targets:
          - localhost
        labels:
          job: nginx-error
          host: {{ ansible_hostname }}
          __path__: /var/log/nginx/error.log
{% endif %}

{% if promtail_scrape_fail2ban %}
  - job_name: fail2ban
    static_configs:
      - targets:
          - localhost
        labels:
          job: fail2ban
          host: {{ ansible_hostname }}
          __path__: /var/log/fail2ban.log
    pipeline_stages:
      - regex:
          expression: '^(?P<timestamp>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2},\d+) (?P<level>\w+)\s+\[(?P<jail>[^\]]+)\] (?P<message>.*)'
      - labels:
          level:
          jail:
{% endif %}

{% if promtail_journal_units | length > 0 %}
  - job_name: journal
    journal:
      max_age: 12h
      labels:
        job: systemd-journal
        host: {{ ansible_hostname }}
    relabel_configs:
      - source_labels: ['__journal__systemd_unit']
        target_label: unit
      - source_labels: ['__journal_priority_keyword']
        target_label: level
      # Only keep logs from configured units
      - source_labels: ['__journal__systemd_unit']
        regex: '{{ promtail_journal_units | map("regex_replace", "$", ".service") | join("|") }}'
        action: keep
{% endif %}
